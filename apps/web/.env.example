# Privy app ID (https://dashboard.privy.io — create an app, paste the App ID)
VITE_PRIVY_APP_ID=cml4ac6iq01s6js0cebe4xl34

# pin-api worker URL (IPFS pinning + membership-key validation)
VITE_PIN_API_URL=https://ipe-gov-pin-api.ipe-gov.workers.dev

# paymaster-proxy worker RPC endpoint — routes pm_*/bundler methods to
# Pimlico (gated by Unlock membership) and falls through to a Sepolia node
# for everything else, so it doubles as the app's read transport.
VITE_PAYMASTER_PROXY_URL=https://ipe-gov-paymaster-proxy.ipe-gov.workers.dev/rpc
