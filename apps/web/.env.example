# Privy app ID (https://dashboard.privy.io — create an app, paste the App ID)
VITE_PRIVY_APP_ID=cml4ac6iq01s6js0cebe4xl34

# pin-api worker URL (IPFS pinning + membership-key validation)
VITE_PIN_API_URL=https://ipe-gov-pin-api.ipe-gov.workers.dev

# paymaster-proxy worker RPC endpoint — base path for the multi-chain RPC.
# The app appends /<chainId> per request (Pimlico-style), so this single URL
# serves Sepolia (sponsored writes + reads), Base (IPE balance reads), and
# Mainnet (ENS reads). Sponsorship is gated by Unlock membership server-side.
VITE_PAYMASTER_PROXY_URL=https://ipe-gov-paymaster-proxy.ipe-gov.workers.dev/rpc

# ens-api worker URL — claims, profile-record edits, and identity lookups
# under the configured ENS parent (govdemo.eth during pilot).
VITE_ENS_API_URL=https://ipe-gov-ens-api.ipe-gov.workers.dev
