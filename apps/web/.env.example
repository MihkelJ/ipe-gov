# Privy app ID (https://dashboard.privy.io — create an app, paste the App ID)
VITE_PRIVY_APP_ID=

# Optional: WalletConnect Cloud project ID — lets Privy expose mobile wallets.
# Leave empty to ship injected-wallet only (MetaMask, Rabby, Brave, …).
VITE_WALLETCONNECT_PROJECT_ID=

# Sepolia RPC (optional; empty = viem public default). Used for contract reads,
# writes, and ENS reverse-resolution against *.ipecity.eth.
VITE_SEPOLIA_RPC_URL=

# pin-api worker URL (IPFS pinning + membership-key validation)
VITE_PIN_API_URL=http://localhost:8787

# paymaster-proxy worker RPC endpoint (ERC-4337 bundler/paymaster)
VITE_PAYMASTER_PROXY_URL=http://localhost:8788/rpc
