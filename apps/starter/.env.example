# Pre-filled with the public community values so the starter runs out of the
# box. Swap in your own at any time — e.g. create a free app at
# https://dashboard.privy.io and replace VITE_PRIVY_APP_ID below.

VITE_PRIVY_APP_ID=cml4ac6iq01s6js0cebe4xl34

# paymaster-proxy worker RPC endpoint — base path for the multi-chain RPC.
# wagmi appends /<chainId> per request, so this single URL serves Sepolia,
# Base, and Mainnet. The proxy gates sponsored writes by Unlock membership.
VITE_PAYMASTER_PROXY_URL=https://ipe-gov-paymaster-proxy.ipe-gov.workers.dev/rpc
