# Local dev secrets for `wrangler dev`. Copy to `.dev.vars` (gitignored).
# For production, set these with `wrangler secret put <NAME>`.

# Pinata JWT for pinning to IPFS — https://app.pinata.cloud/developers/api-keys
PINATA_JWT=

# Comma-separated CORS allowlist (optional; defaults handled in code)
ALLOWED_ORIGINS=http://localhost:5173

# Sepolia reads route through the deployed paymaster-proxy via
# @ipe-gov/sdk's `paymasterProxyRpcUrl` — no RPC URL needed locally.
