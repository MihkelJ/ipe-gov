{
  "$schema": "https://turborepo.com/schema.json",
  "tasks": {
    "build": {
      "dependsOn": ["^build"],
      "outputs": ["dist/**", "artifacts/**", "types/**", ".output/**", ".vinxi/**"]
    },
    "compile": {
      "outputs": ["artifacts/**", "types/**", "cache/**"]
    },
    "dev": {
      "cache": false,
      "persistent": true
    },
    "test": {
      "dependsOn": ["^build"]
    },
    "lint": {},
    "deploy:sepolia": {
      "cache": false,
      "dependsOn": ["compile"]
    }
  }
}
