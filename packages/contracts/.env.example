# Hardhat build-time config (preferred: set via `npx hardhat vars set <NAME>`).
# This file documents the expected values; `process.env` fallbacks also work.

# BIP39 mnemonic for account derivation (local/test only)
MNEMONIC=

# Infura API key — used to build the Sepolia RPC URL
INFURA_API_KEY=

# Private key used for remote deployments (takes precedence over MNEMONIC)
DEPLOYER_PRIVATE_KEY=

# Etherscan API key for contract verification
ETHERSCAN_API_KEY=

# --- Deploy-script runtime flags (process.env) ---

# Set to "1" to force a clean redeploy of delegation contracts
FRESH_DELEGATION=

# Existing Unlock PublicLock address; if unset, a MockPublicLock is deployed
UNLOCK_PUBLIC_LOCK_ADDRESS=

# Governor voting period in blocks (default: 7200 ≈ 1 day on mainnet)
VOTING_PERIOD_BLOCKS=7200

# Set to any truthy value to enable gas reports in tests
REPORT_GAS=
